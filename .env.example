# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Upstash Redis — REST credentials
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional backup Gemini keys. Tried in order when the previous one returns 429
# (daily free-tier quota exhausted) — multiplies the daily embedding ceiling
# without paying for a tier upgrade. A single corpus ingest can exhaust one key.
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=

# Google Gemini — aistudio.google.com/apikey
# Required always: used for corpus embeddings regardless of verify provider below.
GEMINI_API_KEY=

# Optional additional verify-step providers. Set any combination.
# Priority when multiple are set: DeepSeek > OpenAI > Gemini.
# Pin explicitly with LLM_PROVIDER=deepseek|openai|gemini (errors if that key is missing).
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
LLM_PROVIDER=

# Comma-separated emails allowed into /admin (key revoke, flagged usage review)
ADMIN_EMAILS=

# Cloudflare Turnstile (dash.cloudflare.com/?to=/:account/turnstile) — free.
# Protects the landing-page demo widget from scripted abuse. Optional: if
# unset, Turnstile is a no-op (verifyTurnstileToken() always passes).
# TURNSTILE_REQUIRE_FOR_ANONYMOUS=true also blocks keyless /api/v1/check
# calls with no token — breaks the documented "curl it, no key needed"
# free tier, so leave false unless you've decided that tradeoff is worth it.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
TURNSTILE_REQUIRE_FOR_ANONYMOUS=false

# Sentry (sentry.io) — optional server-side error tracking. Inert if unset.
SENTRY_DSN=

# ── General fact-checking evidence sources (domain=general) ──────────
# Free-tier evidence (both tiers). Free to obtain, graceful no-op if unset:
#   Google Fact Check Tools API — console.cloud.google.com, enable
#   "Fact Check Tools API" (may reuse the same Google Cloud project as Gemini).
GOOGLE_FACTCHECK_API_KEY=
# Wikipedia needs no key.
#
# Paid-tier evidence (only used for requests with a valid API key):
#   Tavily — app.tavily.com, free 1000 searches/mo. The primary web source.
TAVILY_API_KEY=
#   GNews (optional) — gnews.io, free 100 req/day, current-events coverage. Skipped if unset.
GNEWS_API_KEY=

# ── Polar.sh billing ───────────────────────────────────────────────
# polar.sh (or sandbox.polar.sh for testing) → Settings:
#   Developers → New Token, scopes checkouts:write / subscriptions:read / customers:read
POLAR_ACCESS_TOKEN=
#   Webhooks → Add Endpoint → https://YOUR_DOMAIN/api/webhooks/polar
#   events: subscription.created / active / updated / canceled / revoked / uncanceled
POLAR_WEBHOOK_SECRET=
#   Products → create "Pro" and "Business" (recurring) → copy each Product ID.
#   See lib/plans.ts for what each plan grants (rate limit, claim depth, domains).
POLAR_PRODUCT_PRO=
POLAR_PRODUCT_BUSINESS=
# "sandbox" while testing with fake cards, "production" once live.
POLAR_SERVER=sandbox
